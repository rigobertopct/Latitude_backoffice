# En desarrollo (npm run dev) el front llama a /api en el mismo origen y Vite reenvía al backend.
# VITE_API_URL (y opcionalmente VITE_PROXY_API) definen a qué host/puerto apunta ese proxy.
VITE_API_URL=http://127.0.0.1:8000
# Si el API corre en otro sitio:
# VITE_PROXY_API=http://127.0.0.1:9000
#
# En build de producción (npm run build) sí se usa VITE_API_URL como base absoluta del API.
